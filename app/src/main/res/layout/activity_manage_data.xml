<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="@dimen/global_margin"
    android:layout_gravity="center">
    <Button
        android:id="@+id/manage_space_uninstall_game"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/manage_data_uninstall_game"
        android:textAllCaps="false"
        app:layout_constraintTop_toTopOf="parent"/>

    <Button
        android:id="@+id/manage_space_uninstall_components"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/manage_data_uninstall_components"
        android:textAllCaps="false"
        android:layout_marginTop="@dimen/global_margin"
        app:layout_constraintTop_toBottomOf="@id/manage_space_uninstall_game" />

    <Button
        android:id="@+id/manage_space_uninstall_everything"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/manage_data_uninstall_everything"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/manage_space_uninstall_components"
        android:layout_marginTop="@dimen/global_margin" />

    <Button
        android:id="@+id/manage_space_open_data_directory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAllCaps="false"
        android:layout_marginTop="@dimen/global_margin"
        android:text="@string/manage_data_share_log_file"
        app:layout_constraintTop_toBottomOf="@id/manage_space_uninstall_everything"/>

</androidx.constraintlayout.widget.ConstraintLayout>